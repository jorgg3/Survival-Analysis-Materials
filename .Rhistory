library(survival)
library(ggplot2)
# Use built-in lung data if the .txt is not available
data(lung)
datos_tarea <- lung
# Fit the non-parametric Kaplan-Meier estimator as a baseline
km_fit <- survfit(Surv(time, status) ~ 1, data = datos_tarea)
# Extract survival probabilities and time for transformation
t <- km_fit$time
S_t <- km_fit$surv
# Filter out S(t) = 0 or 1 to avoid log(0) or undefined quantiles
valid_indices <- S_t > 0 & S_t < 1
t <- t[valid_indices]
S_t <- S_t[valid_indices]
# Use built-in lung data if the .txt is not available
data(lung)
datos_tarea <- lung
# Fit the non-parametric Kaplan-Meier estimator as a baseline
km_fit <- survfit(Surv(time, status) ~ 1, data = datos_tarea)
# Extract survival probabilities and time for transformation
t <- km_fit$time
S_t <- km_fit$surv
# Filter out S(t) = 0 or 1 to avoid log(0) or undefined quantiles
valid_indices <- S_t > 0 & S_t < 1
t <- t[valid_indices]
S_t <- S_t[valid_indices]
# Use built-in lung data if the .txt is not available
data(lung)
datos_tarea <- lung
# Fit the non-parametric Kaplan-Meier estimator as a baseline
km_fit <- survfit(Surv(time, status) ~ 1, data = datos_tarea)
# Extract survival probabilities and time for transformation
t <- km_fit$time
S_t <- km_fit$surv
# Filter out S(t) = 0 or 1 to avoid log(0) or undefined quantiles
valid_indices <- S_t > 0 & S_t < 1
t <- t[valid_indices]
S_t <- S_t[valid_indices]
# Set up a 1x3 grid for comparison
par(mfrow = c(1, 3), mar=c(4,4,3,1))
# --- A. Exponential Diagnostic ---
plot(t, log(S_t),
main = "A. Exponential",
xlab = "t", ylab = "log( S(t) )",
pch = 16, col = "darkblue")
abline(lm(log(S_t) ~ t + 0), col = "red", lwd = 2, lty = 2)
# --- B. Weibull Diagnostic ---
plot(log(t), log(-log(S_t)),
main = "B. Weibull",
xlab = "log( t )", ylab = "log( -log(S(t)) )",
pch = 16, col = "darkgreen")
abline(lm(log(-log(S_t)) ~ log(t)), col = "red", lwd = 2, lty = 2)
# --- C. Log-Normal Diagnostic ---
plot(log(t), qnorm(1 - S_t),
main = "C. Log-normal",
xlab = "log( t )", ylab = "Normal Quantile (1 - S(t))",
pch = 16, col = "purple")
abline(lm(qnorm(1 - S_t) ~ log(t)), col = "red", lwd = 2, lty = 2)
# Reset plot window
par(mfrow = c(1, 1))
# Null Model (Exponential)
mod_exp <- survreg(Surv(time, status) ~ 1, data = datos_tarea, dist = "exponential")
# Alternative Model (Weibull)
mod_wei <- survreg(Surv(time, status) ~ 1, data = datos_tarea, dist = "weibull")
# Extract Log-Likelihoods
logL_exp <- mod_exp$loglik[1]
logL_wei <- mod_wei$loglik[1]
# Calculate the Test Statistic (Lambda): -2 * (logL_null - logL_alt)
lambda_stat <- 2 * (logL_wei - logL_exp)
# Calculate p-value using a Chi-squared distribution (df = 1)
p_val <- pchisq(lambda_stat, df = 1, lower.tail = FALSE)
cat("LRT Statistic (-2 log Lambda):", lambda_stat, "\n")
cat("p-value:", p_val, "\n")
knitr::opts_chunk$set(echo = TRUE)
# Load and prepare the Titanic dataset
data("Titanic")
titanic_df <- as.data.frame(Titanic)
# Expand frequencies to create a tidy dataset
titanic_expanded <- titanic_df[rep(1:nrow(titanic_df), titanic_df$Freq), ]
titanic_expanded$Freq <- NULL
# Create binary survival variable
titanic_expanded$Survived <- ifelse(titanic_expanded$Survived == "Yes", 1, 0)
str(titanic_expanded)
# Fit Logistic Model
logit_model <- glm(Survived ~ Class + Sex + Age,
data = titanic_expanded,
family = binomial(link = "logit"))
summary(logit_model)
# Calculate Odds Ratios: exp(beta)
odds_ratios <- exp(coef(logit_model))
print(odds_ratios)
# Calculate Marginal Effects
# These represent the change in probability for a unit change in the predictor
logit_margins <- margins(logit_model)
# Load necessary libraries
library(tidyverse)
library(broom)
library(margins)
library(pscl)
set.seed(236)
# Fit Logistic Model
logit_model <- glm(Survived ~ Class + Sex + Age,
data = titanic_expanded,
family = binomial(link = "logit"))
summary(logit_model)
# Calculate Odds Ratios: exp(beta)
odds_ratios <- exp(coef(logit_model))
print(odds_ratios)
# Calculate Marginal Effects
# These represent the change in probability for a unit change in the predictor
logit_margins <- margins(logit_model)
summary(logit_margins)
data("warpbreaks")
summary(warpbreaks)
# Fit Poisson Model
poisson_model <- glm(breaks ~ wool + tension,
data = warpbreaks,
family = poisson(link = "log"))
summary(poisson_model)
# Calculate Incidence Rate Ratios (IRR)
irr_poisson <- exp(coef(poisson_model))
print(irr_poisson)
# Overdispersion Diagnostic (Ratio of Pearson chi-square to degrees of freedom)
# If dispersion > 1, the variance exceeds the mean, violating Poisson assumptions.
dispersion_ratio <- sum(residuals(poisson_model, type = "pearson")^2) /
poisson_model$df.residual
cat("Dispersion Ratio:", dispersion_ratio, "\n")
# Fit Quasi-Poisson Model
quasi_model <- glm(breaks ~ wool + tension,
data = warpbreaks,
family = quasipoisson(link = "log"))
summary(quasi_model)
